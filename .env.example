# AutoApplyAI Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=AutoApplyAI
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-64-char-string
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://autoapplyai:autoapplyai_secret@db:5432/autoapplyai
DATABASE_URL_SYNC=postgresql://autoapplyai:autoapplyai_secret@db:5432/autoapplyai

# Redis
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT
JWT_SECRET_KEY=change-me-jwt-secret-key-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Service (OpenAI)
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# File Storage
UPLOAD_DIR=/app/uploads
MAX_RESUME_SIZE_MB=10

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
MAX_APPLICATIONS_PER_DAY=50

# Playwright
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Monitoring (optional)
SENTRY_DSN=
